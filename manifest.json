{
  "manifest_version": 3,
  "name": "Upwork Proposal Generator",
  "version": "1.0.0",
  "description": "Generate short, human-written proposals for Upwork jobs using Gemini AI",
  "permissions": ["storage"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
