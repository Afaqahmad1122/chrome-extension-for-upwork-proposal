{
  "manifest_version": 3,
  "name": "Upwork Proposal Generator",
  "version": "1.1.0",
  "description": "Generate short, human-written proposals for Upwork jobs using Gemini AI",
  "permissions": ["storage", "sidePanel"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Upwork Proposal Generator",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
